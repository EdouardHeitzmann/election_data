{"metadata":{"name":{"year":"Generic","authority":"Made up","name":"Dummy first preference","electorate":"DummyFirstPreference","comment":"This is an example of how adding a sure to lose party as a first preference by one voter increases the power of their vote, making candidate `O' win rather than `P' who would have won. See similar DummyFirstPreferenceAlternative.stv for the alternate situation."},"candidates":[{"name":"C1","party":0,"position":1},{"name":"C2","party":0,"position":2},{"name":"A1","party":1,"position":1},{"name":"A2","party":1,"position":2},{"name":"P","party":2,"position":1},{"name":"O","party":3,"position":1},{"name":"E","party":4,"position":1}],"parties":[{"column_id":"A","name":"Clockwise Coalition","atl_allowed":true,"candidates":[0,1]},{"column_id":"B","name":"Anticlockwise Alliance","atl_allowed":true,"candidates":[2,3]},{"column_id":"C","name":"Clockphobics","atl_allowed":true,"candidates":[4]},{"column_id":"D","name":"Only Clocks","atl_allowed":true,"candidates":[5]},{"column_id":"E","name":"Gratuitous Evil","atl_allowed":true,"candidates":[6]}],"vacancies":3},"atl":[{"parties":[0,1],"n":110},{"parties":[1,2],"n":120},{"parties":[2],"n":74},{"parties":[3],"n":93},{"parties":[4,0,3],"n":1}],"btl":[],"informal":0}